# Configurações da API
PORT=3000
NODE_ENV=development

# Timeouts
PROVIDER_TIMEOUT=10000

# Observabilidade — OpenTelemetry / Dynatrace
# Deixe OTEL_ENABLED=false (padrão) para desabilitar
# Para ativar: npm install @opentelemetry/sdk-node @opentelemetry/auto-instrumentations-node @opentelemetry/exporter-trace-otlp-http
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cep-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
